# Copy to .env and adjust. Postgres connection for the persistence layer (Phase 2).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/island_life

# Phase 5 (narrative). Lives only in the narrative service env; never shipped to the client.
# Set ONE provider key to enable Layer-2 prose. DeepSeek (cheap) is preferred when both are set.
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat        # optional override
# ANTHROPIC_API_KEY=
